# Backend server
BACKEND_PORT=5000
MONGODB_URI=mongodb://localhost:27017/quickcook
JWT_SECRET=your-jwt-secret

# Frontend URL for reset link generation
FRONTEND_URL=http://localhost:5173

# SMTP / Gmail configuration for forgot-password emails
# For Gmail, use an App Password (not your regular account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="QuickCook <yourgmail@gmail.com>"
